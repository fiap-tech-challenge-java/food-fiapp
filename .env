# ------------------------------------------------------------------------------
# SPRING / PERFIL
# ------------------------------------------------------------------------------
SPRING_PROFILES_ACTIVE=local          # antes: SPRING_PROFILE
SHOW_SQL=true

# ------------------------------------------------------------------------------
# JWT (token e expiração)
# ------------------------------------------------------------------------------
JWT_SECRET=yX56ambwC9AM8QkQzYOpHr0wYviQizzneZBtbeO+IfY=
JWT_EXPIRATION_MS=604800000

# ------------------------------------------------------------------------------
# BANCO DE DADOS
# ------------------------------------------------------------------------------
DB_NAME=foodfiapp
DB_USERNAME=postgres
DB_PASSWORD=postgrespass
DB_PORT=5439
DB_HOST=localhost                     # usado só localmente
SPRING_DATASOURCE_URL=jdbc:postgresql://${DB_HOST}:${DB_PORT}/${DB_NAME}
SPRING_DATASOURCE_USERNAME=${DB_USERNAME}
SPRING_DATASOURCE_PASSWORD=${DB_PASSWORD}

# ------------------------------------------------------------------------------
# MINIO (armazenamento de imagens)
# ------------------------------------------------------------------------------
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=menu-items

# ------------------------------------------------------------------------------
# OPENAPI (para build)
# ------------------------------------------------------------------------------
export OPENAPI_SHA=$(sha256sum src/main/resources/openapi/openapi.yaml | awk '{print $1}')

# ------------------------------------------------------------------------------
# SEED / ADMIN INICIAL (executado pelo Flyway ou Runner)
# ------------------------------------------------------------------------------
SEED_ON_START=true
ADMIN_EMAIL=admin@foodfiapp.local
ADMIN_LOGIN=admin_foodfiapp
ADMIN_PASSWORD=passwordAdminFoodfiapp123
