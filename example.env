# ================================================================
# 🌱 FoodFiApp - Example Environment Variables
# ================================================================
# Copie este arquivo para .env e preencha com seus valores reais.
# Nunca commite seu arquivo .env com segredos!
# ================================================================

# ---------------------------------------------------------------
# SPRING / PERFIL
# ---------------------------------------------------------------
SPRING_PROFILES_ACTIVE=local
SHOW_SQL=true

# ---------------------------------------------------------------
# JWT (Token de autenticação)
# ---------------------------------------------------------------
# Gere um segredo seguro (ex: `openssl rand -base64 32`)
JWT_SECRET=CHANGE_ME_TO_A_SECURE_RANDOM_SECRET
JWT_EXPIRATION_MS=604800000   # 7 dias

# ---------------------------------------------------------------
# BANCO DE DADOS
# ---------------------------------------------------------------
DB_NAME=foodfiapp
DB_USERNAME=postgres
DB_PASSWORD=postgrespass
DB_PORT=5439
DB_HOST=localhost
SPRING_DATASOURCE_URL=jdbc:postgresql://${DB_HOST}:${DB_PORT}/${DB_NAME}
SPRING_DATASOURCE_USERNAME=${DB_USERNAME}
SPRING_DATASOURCE_PASSWORD=${DB_PASSWORD}

# ---------------------------------------------------------------
# MINIO (armazenamento de imagens)
# ---------------------------------------------------------------
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=menu-items

# ---------------------------------------------------------------
# OPENAPI (usado no build Docker)
# ---------------------------------------------------------------
# Calcula o hash SHA do arquivo OpenAPI para garantir integridade
# export OPENAPI_SHA=$(sha256sum src/main/resources/openapi/openapi.yaml | awk '{print $1}')
OPENAPI_SHA=<gerar_comando_ou_remover_para_local>

# ---------------------------------------------------------------
# SEED / ADMIN INICIAL (executado automaticamente no Docker)
# ---------------------------------------------------------------
SEED_ON_START=true
ADMIN_EMAIL=admin@foodfiapp.local
ADMIN_LOGIN=admin_foodfiapp
ADMIN_PASSWORD=ChangeMe123!

# ---------------------------------------------------------------
# OUTROS
# ---------------------------------------------------------------
# Adicione aqui variáveis personalizadas se necessário
# Ex: LOG_LEVEL, S3_REGION, etc.
